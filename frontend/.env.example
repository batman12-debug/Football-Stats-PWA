# Server-only backend URL (SSR + API route proxy). Required on Netlify.
# Example: https://goalmind-api.onrender.com
API_URL=http://localhost:8000

# Optional fallback if API_URL is unset. Prefer API_URL in production.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Netlify deployment ---
# 1. Push repo to GitHub; Netlify → Import project → pick repo (reads /netlify.toml).
# 2. Site settings → Environment variables → add API_URL (HTTPS Render URL).
# 3. On Render, set NEXT_PUBLIC_FRONTEND_URL + CORS_ORIGINS to your Netlify URL.
# 4. Custom domain (optional): checkboardpk.com in Netlify; api subdomain on Render.
