# Server-only backend URL (SSR + API route proxy). Required on Netlify.
# Example: https://goalmind-api.onrender.com
API_URL=http://localhost:8000

# Optional fallback if API_URL is unset. Prefer API_URL in production.
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Netlify deployment ---
# 1. Connect repo; Netlify reads /netlify.toml (base = frontend).
# 2. Set API_URL to your hosted FastAPI backend (HTTPS required in production).
# 3. On the backend, set NEXT_PUBLIC_FRONTEND_URL to your Netlify site URL
#    (e.g. https://goalmind.netlify.app) and add it to CORS_ORIGINS if needed.
# 4. Deploy previews: set API_URL per context in Netlify UI if using a staging API.
