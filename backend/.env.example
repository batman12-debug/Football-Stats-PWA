# API-Football (https://www.api-football.com/)
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# Supabase — use SERVICE ROLE key on backend only (never expose to frontend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# Upstash Redis (REST API credentials from Upstash dashboard)
UPSTASH_REDIS_URL=https://your-redis.upstash.io
UPSTASH_REDIS_TOKEN=your_upstash_redis_token_here

# Data source: hybrid (free), statsbomb, openfootball, or api_football (paid)
DATA_SOURCE=hybrid

# StatsBomb open data — historical World Cups (2018, 2022)
STATSBOMB_COMPETITION_ID=43
STATSBOMB_SEASON_IDS=106,3

# OpenFootball — WC 2026 fixture schedule (public domain)
OPENFOOTBALL_WC_YEAR=2026

# API-Football (only used when DATA_SOURCE=api_football)
WC_LEAGUE_ID=1
WC_SEASON=2022

# App
ENVIRONMENT=development
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Netlify production example (backend hosted separately):
# ENVIRONMENT=production
# NEXT_PUBLIC_FRONTEND_URL=https://your-site.netlify.app
# CORS_ORIGINS=https://your-site.netlify.app
# TRUSTED_HOSTS=api.yourdomain.com
# TRUST_PROXY_HEADERS=true

# Admin — required to POST /api/matches/{id}/result (generate a long random string)
ADMIN_API_KEY=

# Production hardening (set when ENVIRONMENT=production)
# TRUSTED_HOSTS=api.yourdomain.com,localhost
# TRUST_PROXY_HEADERS=true
